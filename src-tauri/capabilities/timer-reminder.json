{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "timer-reminder",
  "description": "Least-privilege capability for the no-active-timer reminder",
  "windows": ["timer-reminder"],
  "permissions": [
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:allow-hide",
    "store:allow-load",
    "store:allow-get",
    "log:allow-log"
  ]
}
